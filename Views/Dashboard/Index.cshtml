@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<h2 class="text-center mb-4">📊 Dashboard Administrativo</h2>

<div class="row text-center mb-4">

    <div class="col-md-4">
        <div class="card shadow p-3">
            <h4>🏨 Hoteles</h4>
            <h2 class="text-primary">@ViewBag.TotalHoteles</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow p-3">
            <h4>👤 Usuarios</h4>
            <h2 class="text-success">@ViewBag.TotalUsuarios</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow p-3">
            <h4>📅 Reservas</h4>
            <h2 class="text-danger">@ViewBag.TotalReservas</h2>
        </div>
    </div>

</div>

<hr />

<h3 class="text-center">📈 Reservas por Mes</h3>

<div class="col-md-10 offset-md-1">
    <canvas id="chartReservas"></canvas>
</div>

<!-- CHART JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ReservasMesLabels));
    const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ReservasMesValues));

    new Chart(document.getElementById('chartReservas'), {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: "Reservas por Mes",
                data: values,
                borderWidth: 1
            }]
        }
    });
</script>